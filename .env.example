# ─────────────────────────────────────────────────────────────────
# NUUN Creative Lab — Environment Variables
# Copy this file to .env.local for local development.
# Set the same variables in the Cloudflare Pages dashboard for staging/production.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# Base URL for canonical links, OG metadata, and sitemap generation.
# No trailing slash.
# Local dev:  http://localhost:3000
# Staging:    https://nuun-lab.nuunmarketing.workers.dev
# Production: https://nuun.dev
NEXT_PUBLIC_SITE_URL=https://nuun.dev

# Google Analytics 4 measurement ID.
# Leave blank to disable analytics entirely.
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-EDN49957S3

# GHL (GoHighLevel) scheduling form URL.
# If set, "Join the Revolution" CTAs link directly to this URL.
# If unset, CTAs fall back to /contact (where the booking embed lives).
# Leave blank unless you have a standalone GHL booking URL.
NEXT_PUBLIC_GHL_BOOKING_URL=
